# Copy this file to .env and adjust values for your environment.
# docker compose reads .env automatically.

LISTEN_ADDR=:8080

# URL of the Ollama instance the proxy forwards requests to.
# Use "http://ollama:11434" when Ollama runs inside the same compose stack.
# Use "http://host.docker.internal:11434" for Ollama on the host (Mac/Windows).
# Use "http://172.17.0.1:11434" for Ollama on the host (Linux, docker bridge).
# Use "http://<ip>:11434" for Ollama on a remote machine.
OLLAMA_UPSTREAM=http://ollama:11434

# Persistent data paths inside the container (bind-mounted from ./data/).
DB_PATH=/data/db.sqlite
LOG_PATH=/data/logs/proxy.log

PROXY_PORT=8080
FRONTEND_PORT=3000
OLLAMA_PORT=11434
PROMETHEUS_PORT=9090
